@model AtmSimulator.ViewModels.PinViewModel

@{
    ViewData["Title"] = "Enter PIN";
}

<div class="atm-screen">
    <div class="atm-card">
        <div class="atm-header">
            <h1>Enter PIN</h1>
            <p class="text-muted">Enter your 4-digit PIN</p>
        </div>

        <form asp-action="EnterPin" method="post">
            <div class="form-group">
                <label asp-for="Pin" class="form-label">PIN</label>
                <input asp-for="Pin"
                       class="form-control text-center"
                       type="password"
                       placeholder="••••"
                       maxlength="4" />
                <span asp-validation-for="Pin" class="text-danger"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mt-3"></div>

            <button type="submit" class="btn-atm mt-4">
                Confirm →
            </button>

            <a asp-action="InsertCard" class="btn-atm-outline mt-2">
                ← Cancel
            </a>
        </form>
    </div>
</div>
