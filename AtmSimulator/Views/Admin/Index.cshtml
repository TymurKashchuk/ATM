@model AtmSimulator.ViewModels.AdminAccountListViewModel

@{
    ViewData["Title"] = "Admin Panel";
}

<div class="atm-screen">
    <div class="atm-card" style="max-width: 700px;">
        <div class="atm-header" style="display:flex; justify-content:space-between; align-items:center;">
            <h1>Admin Panel</h1>
            <a href="/Admin/AdminLogout" class="btn-atm-outline" style="width:auto; padding:0.5rem 1rem;">Вийти</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert-success-atm">@TempData["Success"]</div>
        }

        <form method="get" style="display:flex; gap:0.5rem; margin-bottom:1rem;">
            <input type="text" name="search" value="@Model.SearchQuery"
                   class="form-control" placeholder="Пошук за ім'ям або номером картки" />
            <button type="submit" class="btn-atm-outline" style="width:auto; padding: 0.75rem 1.25rem;">Знайти</button>
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <a href="/Admin/Index" class="btn-atm-outline" style="width:auto; padding: 0.75rem 1.25rem;">Скинути</a>
            }
        </form>

        <a href="/Admin/Create" class="btn-atm mb-3">+ Новий акаунт</a>

        @foreach (var account in Model.Accounts)
        {
            <div class="transaction-item" style="margin-bottom:0.5rem; flex-wrap:wrap; gap:0.5rem;">
                <div class="transaction-info">
                    <p class="transaction-type">@account.OwnerName</p>
                    <p class="transaction-date">@account.CardNumber</p>
                </div>
                <div class="transaction-amount" style="color:#60a5fa;">
                    @account.Balance.ToString("N2") ₴
                </div>
                <div>
                    @if (account.IsBlocked)
                    {
                        <span style="color:#e94560; font-size:0.8rem;">Заблокована</span>
                    }
                    else
                    {
                        <span style="color:#4ade80; font-size:0.8rem;">Активна</span>
                    }
                </div>
                <form method="post" action="/Admin/ToggleBlock">
                    <input type="hidden" name="accountId" value="@account.Id" />
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-atm" style="width:auto; padding:0.5rem 1rem; font-size:0.85rem; background:@(account.IsBlocked ? "#4ade80" : "#e94560")">
                        @(account.IsBlocked ? "Розблокувати" : "Заблокувати")
                    </button>
                </form>
            </div>
        }
    </div>
</div>