@model AtmSimulator.ViewModels.TransferViewModel

@{
    ViewData["Title"] = "Transfer";
}

<div class="atm-screen">
    <div class="atm-card">
        <div class="atm-header">
            <h1>Transfer</h1>
            <p class="text-muted">Available: <strong style="color:#4ade80">@Model.CurrentBalance.ToString("N2") ₴</strong></p>
        </div>

        <form asp-action="Transfer" method="post">
            <div class="form-group">
                <label asp-for="RecipientCardNumber" class="form-label">Recipient Card Number</label>
                <input asp-for="RecipientCardNumber"
                       class="form-control"
                       placeholder="1234567890123456"
                       maxlength="16" />
                <span asp-validation-for="RecipientCardNumber" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <label asp-for="Amount" class="form-label">Amount (₴)</label>
                <input asp-for="Amount"
                       class="form-control"
                       placeholder="e.g. 500" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mt-3"></div>

            <button type="submit" class="btn-atm mt-4">Transfer →</button>
            <a asp-controller="Account" asp-action="Index" class="btn-atm-outline mt-2">← Back</a>
        </form>
    </div>
</div>