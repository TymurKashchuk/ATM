@model AtmSimulator.ViewModels.TransactionHistoryViewModel

@{
    ViewData["Title"] = "Transaction History";
}

<div class="atm-screen">
    <div class="atm-card" style="max-width: 560px;">
        <div class="atm-header">
            <h1>Transaction History</h1>
            <p class="text-muted">Total: @Model.TotalCount transactions</p>
        </div>

        @if (!Model.Transactions.Any())
        {
            <div class="empty-state">
                <p>No transactions yet</p>
            </div>
        }
        else
        {
            <div class="transaction-list">
                @foreach (var t in Model.Transactions)
                {
                    <div class="transaction-item">
                        <div class="transaction-icon @t.Type.ToString().ToLower()">
                            @switch (t.Type)
                            {
                                case AtmSimulator.Models.TransactionType.Withdrawal:
                                    <span>↑</span>
                                    break;
                                case AtmSimulator.Models.TransactionType.Deposit:
                                    <span>↓</span>
                                    break;
                                case AtmSimulator.Models.TransactionType.Transfer:
                                    <span>⇄</span>
                                    break;
                            }
                        </div>
                        <div class="transaction-info">
                            <p class="transaction-type">@t.Type</p>
                            <p class="transaction-date">@t.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                        </div>
                        <div class="transaction-amount @(t.Type == AtmSimulator.Models.TransactionType.Deposit ? "positive" : "negative")">
                            @(t.Type == AtmSimulator.Models.TransactionType.Deposit ? "+" : "-")@t.Amount.ToString("N2") ₴
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="pagination">
                    @if (Model.CurrentPage > 1)
                    {
                        <a asp-action="History" asp-route-page="@(Model.CurrentPage - 1)" class="page-btn">←</a>
                    }
                    <span class="page-info">@Model.CurrentPage / @Model.TotalPages</span>
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a asp-action="History" asp-route-page="@(Model.CurrentPage + 1)" class="page-btn">→</a>
                    }
                </div>
            }
        }

        <a asp-controller="Account" asp-action="Index" class="btn-atm-outline mt-3">← Back</a>
    </div>
</div>